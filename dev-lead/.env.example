# Dev Lead — authorized key shapes only
#
# Never place real values in this file and do not copy it to a local `.env`.
# The platform binds the exact role-authorized values from Infisical at runtime.
# See ../SECRETS_MATRIX.md for scope and provisioning rules.

# Per-persona Gitea credential scoped to the Dev Lead's assigned repositories.
GITEA_TOKEN=

# Bind only the credential required by the runtime/model selected for this
# workspace. The platform may expose one of these shapes; no provider is the
# hard-coded organization default.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
OPENAI_API_KEY=
